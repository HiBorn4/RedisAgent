# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SEC=3600

# ── MCP Server ─────────────────────────────────────────────────────────────────
MCP_SERVER_CMD=python3
MCP_SERVER_ARGS=server.py

# ── Google ADK / Gemini ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=false

# ── SAP / Enterprise API (optional – used by utils.py) ────────────────────────
ES_USERNAME=
ES_PASSWORD=
EMP_API_KEY=
